# Email Configuration for Contact Form
# To use Gmail SMTP, you need to:
# 1. Enable 2-Factor Authentication on your Google account
# 2. Generate an App Password at https://myaccount.google.com/apppasswords
# 3. Use the App Password (not your regular Gmail password) below

EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# Google Places API (for displaying Google Business reviews on the home page)
# 1. Create a project + enable the "Places API (New)" in Google Cloud Console
# 2. Create an API key (restrict it to the Places API) at
#    https://console.cloud.google.com/apis/credentials
# 3. Find your Place ID at https://developers.google.com/maps/documentation/places/web-service/place-id
# Reviews are hidden automatically if these are not set.
GOOGLE_PLACES_API_KEY=your-places-api-key
GOOGLE_PLACE_ID=your-place-id
